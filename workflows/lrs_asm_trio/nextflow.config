/*
========================================================================================
    LRS_ASM_TRIO NEXTFLOW CONFIGURATION
========================================================================================
    Configuration file for the lrs_asm_trio trio assembly and variant calling pipeline.

    Profiles:
        standard  -- local execution (default)
        hpc       -- example SLURM/HPC configuration (edit to match your cluster)
        gcb       -- Google Cloud Batch execution (edit to match your GCP project)

    Required parameters (must be set by user):
        --csv_path                        path to input samplesheet CSV
        --outputDir                       path to output directory
        --reference_file_path             path to reference genome FASTA (e.g. hg38.no_alt.fa)
        --reference_index_file_path       path to reference FASTA index (.fai)
        --refs_path                       path to directory containing reference resource files
        --scripts_path                    path to directory containing pipeline scripts

    Expected samplesheet format:
        sID,proband_hifi_fastq,mat_hifi_fastq,pat_hifi_fastq,HPO
        SAMPLE01,/path/to/proband.fastq.gz,/path/to/mat.fastq.gz,/path/to/pat.fastq.gz,/path/to/HPO.txt

    Pipeline scripts (expected under scripts_path):
        filter_svanna_pav.R  -- filter and rank SvAnna-prioritized PAV SV candidates
========================================================================================
*/

profiles {

    standard {
        process.executor = 'local'
    }

    hpc {
        // Example SLURM + Singularity configuration -- edit to match your cluster
        process.executor       = 'slurm'
        process.queue          = 'your_queue_name'
        process.clusterOptions = '--account=your_account'
        process.memory         = '16 GB'
        process.time           = '21h'
        process.beforeScript   = 'module load singularity'
        workDir                = '/path/to/scratch/workdir'

        singularity {
            enabled    = true
            autoMounts = true
            cacheDir   = '/path/to/singularity/cache'
            runOptions = '--bind /path/to/data:/path/to/data'
        }

        executor {
            name            = 'slurm'
            queueSize       = 150
            submitRateLimit = '1 / 2 s'
        }
    }

    gcb {
        // Google Cloud Batch configuration -- edit to match your GCP project
        process.executor        = 'google-batch'
        process.disk            = '500 GB'
        process.errorStrategy   = 'finish'
        process.machineType     = 'n2-highmem-16'
        workDir                 = 'gs://your-bucket/lrs_asm_trio/work_dir'
        google.region           = 'us-east1'
        google.location         = 'us-east1'
        google.project          = 'your-gcp-project'
    }

}

def now() {
    return new Date().format("yyyy-MM-dd")
}

params {

    // -----------------------------------------------------------------------
    // Input / output
    // -----------------------------------------------------------------------
    csv_path  = null
    outputDir = "/path/to/output/${now()}/"
    workDir   = "/path/to/workdir/${now()}/"

    // -----------------------------------------------------------------------
    // Reference genome
    // -----------------------------------------------------------------------
    referenceID                 = "hg38"
    refs_path                   = "/path/to/refs"
    scripts_path                = "/path/to/scripts"
    reference_file_path         = "${refs_path}/hg38.no_alt.fa"
    reference_index_file_path   = "${refs_path}/hg38.no_alt.fa.fai"

    // -----------------------------------------------------------------------
    // Threading
    // -----------------------------------------------------------------------
    n_proc = 64   // threads for: PAV, Yak

    // -----------------------------------------------------------------------
    // Tool-specific parameters
    // -----------------------------------------------------------------------

    hifiasm {
        threads = 96   // threads for HiFiasm
    }

    svAnna {
        threads                  = 96   // threads for SvAnna prioritization
        pav_svanna_r_script_path = "${scripts_path}/filter_svanna_pav.R"
    }

}

process {
    // Uncomment the line below if running with Apptainer/Singularity on an HPC
    // module = 'apptainer'
}