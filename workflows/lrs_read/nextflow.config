/*
========================================================================================
    LRS_READ NEXTFLOW CONFIGURATION
========================================================================================
    Configuration file for the lrs_read long-read sequencing analysis pipeline.

    Profiles:
        standard  -- local execution (default)
        hpc       -- SLURM/HPC configuration (Sumner2)
        gcb       -- Google Cloud Batch execution (edit to match your GCP project)

    Required parameters (must be set by user):
        --csv_path                   path to input samplesheet CSV
        --outputDir                  path to output directory
        --reference_file_path        path to reference genome FASTA (e.g. hg38.no_alt.fa)
        --reference_index_file_path  path to reference FASTA index (.fai)
        --refs_path                  path to directory containing reference resource files
        --scripts_path               path to directory containing pipeline scripts

    Reference resource files (expected under refs_path):
        hg38.no_alt.fa                                        reference genome FASTA
        hg38.no_alt.fa.fai                                    reference genome index
        human_GRCh38_no_alt_analysis_set.trf.bed             tandem repeat regions (pbsv)
        human.hg38.excl.tsv                                   exclusion regions (Delly)
        cnv.excluded_regions.common_50.hg38.bed.gz           exclusion regions (HiFiCNV)
        medically_relevant_repeats_hg38.bed                  clinically relevant repeats (TRGT)
        SVAFotate_core_SV_popAFs.GRCh38.v4.1_LR_v2.0_INS1bp.bed.gz  SVAFotate frequency database
        meth_profile_model.tsv                               methylation region profile model
        targetGenes.txt                                      target genes for Paraphase extraction

    Pipeline scripts (expected under scripts_path):
        coverage.py                      compute mean sequencing depth
        convert_paraphase.R              extract CN and variants from Paraphase JSON
        filter_svanna_pbsv_sniffles2.R   filter and merge SvAnna SV candidates
========================================================================================
*/

profiles {

    standard {
        process.executor = 'local'
    }

    hpc {
        apptainer {
            enabled    = true
            autoMounts = true
            cacheDir   = "/flashscratch/werrel/containers"
            runOptions = '--bind /flashscratch:/flashscratch --bind /projects:/projects --bind /home:/home'
        }

        process {
            executor       = 'slurm'
            beforeScript   = 'export PATH=/cm/local/apps/apptainer/current/bin:$PATH'
            queue          = 'compute'
            clusterOptions = { task.time < 72.h ? '-q batch' : '-q long' }
            memory         = '16 GB'
            time           = '21h'
        }

        executor {
            name            = 'slurm'
            queueSize       = 150
            submitRateLimit = '1 / 2 s'
        }
    }

    gcb {
        process.executor            = 'google-batch'
        process.disk                = '500 GB'
        process.errorStrategy       = 'finish'
        workDir                     = 'gs://your-bucket/lrs_read/work_dir'
        google.region               = 'us-east1'
        google.location             = 'us-east1'
        google.project              = 'your-gcp-project'
    }

}

def now() {
    return new Date().format("yyyy-MM-dd")
}

params {

    // -----------------------------------------------------------------------
    // Input / output
    // -----------------------------------------------------------------------
    csv_path  = null
    runDate   = new Date().format('yyyyMMdd')
    outputDir = "/flashscratch/${System.getenv('USER')}/jax-apml-lrs/"
    workDir   = "/flashscratch/${System.getenv('USER')}/tmpwork/${now()}/"

    // -----------------------------------------------------------------------
    // Reference genome
    // -----------------------------------------------------------------------
    referenceID               = "hg38"
    refs_path                 = params.refs_path
    scripts_path              = "${launchDir}/resources/scripts"
    reference_file_path       = "${refs_path}/hg38.no_alt.fa"
    reference_index_file_path = "${refs_path}/hg38.no_alt.fa.fai"

    // -----------------------------------------------------------------------
    // Threading
    // -----------------------------------------------------------------------
    NTHREAD = 8
    MORECPU = 64

    // -----------------------------------------------------------------------
    // Resource files
    // -----------------------------------------------------------------------
    repeats_path = "${refs_path}/medically_relevant_repeats_hg38.bed"
    ref_trf_path = "${refs_path}/human_GRCh38_no_alt_analysis_set.trf.bed"

    // -----------------------------------------------------------------------
    // Tool-specific parameters
    // -----------------------------------------------------------------------

    pbmm2 {
        cpus         = params.MORECPU
        sort_threads = 4
        sort_memory  = '8G'
        mem          = '128 GB'
    }

    quality_metrics {
        cpus                    = params.NTHREAD
        getcoverage_script_path = "${scripts_path}/coverage.py"
    }


    delly {
        min_mapping_quality = 20
        alignment_scoring   = 15
        min_clique_size     = 5
        hg38_excl_path      = "${refs_path}/human.hg38.excl.tsv"
    }

    CNVs_HiFiCNV {
        excl_region_path = "${refs_path}/cnv.excluded_regions.common_50.hg38.bed.gz"
    }

    Paraphase {
        paraphase_threads             = 8
        extract_paraphase_json_r_path = "${scripts_path}/convert_paraphase.R"
        target_genes_txt_path         = "${refs_path}/targetGenes.txt"
    }

    svAnna {
        svanna_sif_path = "${refs_path}/svanna_v1.0.4.sif"
        pbsv_sniffles_2_svanna_r_script_path = "${scripts_path}/filter_svanna_pbsv_sniffles2.R"
    }

    methbat {
        meth_input_regions = "${refs_path}/meth_profile_model.tsv"
        cpus               = params.NTHREAD
        mem                = '32 GB'
    }

    svafotate {
        overlap       = 0.8
        svafotate_bed = "${refs_path}/SVAFotate_core_SV_popAFs.GRCh38.v4.1_LR_v2.0_INS1bp.bed.gz"
        cpus          = params.NTHREAD
        mem           = '64 GB'
    }

}

process {
    beforeScript = 'export PATH=/cm/local/apps/apptainer/current/bin:\$PATH'
}
